# Lockfiles — engine has zero runtime deps; we don't ship a lock
package-lock.json
yarn.lock

# Round 7 — local witness files (generated by `npm run verify`)
# CI-generated witnesses are published as workflow artifacts + release assets.
attestations/latest.json
attestations/witness-*.json

# v2.9.25 — SHA-256 sidecar files (regenerated by `npm run attest`).
# Canonical pinned values live in DAUBERT.md §3.1; sidecars are a
# mechanically-diffable convenience for local verification.
cpm-engine.js.sha256
python_reference/cpm.py.sha256

# Defensive secret-pattern blocklist — these should never be committed.
# Reflects the SECURITY.md scope: zero runtime deps means zero accidental
# secret material in the tree either.
*.key
*.pem
id_rsa*
id_dsa*
id_ecdsa*
id_ed25519*
credentials
credentials.*
secrets
secrets.*
.netrc
.npmrc
