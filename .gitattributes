# Normalize line endings to LF for all text files checked into this repo.
# This ensures consistent diffs and avoids CRLF/LF churn across Windows/Mac/Linux.
* text=auto
*.js text eol=lf
*.md text eol=lf
*.json text eol=lf
*.ts text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
# Critical: python_reference/cpm.py is pinned by SHA-256. CRLF would change
# the byte content and invalidate the hash documented in
# python_reference/README.md and DAUBERT.md §3. Force LF for all .py.
*.py text eol=lf
